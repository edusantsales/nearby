# ===========================================================================
# Dart & Flutter
# ===========================================================================
# ATENÇÃO: Nunca ignore arquivos *.lock (como pubspec.lock, Podfile.lock) em 
# aplicações finais. Eles garantem que todo o time e a esteira de CI/CD utilizem 
# exatamente as mesmas versões das dependências, evitando builds "quebrados".
# Para packages/libraries Dart, é recomendado não commitar os arquivos .lock para permitir flexibilidade na escolha das versões. 
# Mais informações: https://dart.dev/guides/libraries/private-files#pubspeclock
*.lock
!pubspec.lock
!Podfile.lock
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
coverage/

# ===========================================================================
# Builds
# ===========================================================================
.build/
.buildlog/
build/
**/build/*

# Informações de build e debug
**/doc/api/
**/ios/Flutter/.last_build_id
app.*.symbols
app.*.map.json
devtools_options.yaml

# ===========================================================================
# Registrants e Código Gerado (codegen/build_runner)
# ===========================================================================
lib/generated_plugin_registrant.dart
**/android/**/GeneratedPluginRegistrant.java
**/ios/**/GeneratedPluginRegistrant.{h,m}
**/macos/**/GeneratedPluginRegistrant.swift

# Bibliotecas (freezed, json_serializable, mobx, get_it, etc)
*.g.dart
*.freezed.dart
*.chopper.dart
*.config.dart
*.mocks.dart

# ===========================================================================
